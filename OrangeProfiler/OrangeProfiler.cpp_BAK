// Set the global configurations
DWORD g_DiagnosticInfoLevel = TRACELEVEL_ERROR;     
FILE * g_pLog = NULL;



unsigned __stdcall ForceGCThreadStub(void * p)
{    
    OrangeProfiler * pOp = (OrangeProfiler *) p;
    pOp->ThreadStubWrapper();
    return 0;
}



OrangeProfiler::OrangeProfiler() 
: m_bIsWOW64Process           (FALSE),
  m_hProc                     (NULL),
  m_dwPid                     (0),
  m_cRef                      (1),
  m_dwWorkerThreadId          (0),
  m_hndWorkerThread           (NULL),
  m_bWorkerThreadExit         (FALSE),
  m_pStats                    (NULL),
  m_pInfo                     (NULL),
  m_wszCustomSnapshotAction   (NULL),
  m_cGCRefCnt                 (0),
  m_dwOptions                 (DUMP_GENRANGES | DUMP_HEAP), // change this later. 
  m_bAttachingProfiler		  (FALSE)
{
    // system specific variables get initialized first
    ZeroMemory(& m_sysInfo, sizeof(m_sysInfo));

    // and then the process specific ones
    ZeroMemory(m_wszFilePath, 2 * MAX_PATH * sizeof(WCHAR));
    ZeroMemory(m_wszFileName, 2 * MAX_PATH * sizeof(WCHAR));

    // and then the profiler specific ones
    InitializeCriticalSection(& m_cs);

    // and finally the profiling session specific ones
    m_mapHeapObjects.clear();
	m_classIdLookup.clear();
	m_objectIdLookup.clear();

    RetrieveSystemAndProcessInfo();
}


OrangeProfiler::~OrangeProfiler() 
{
    // first clear the profiling session specific variables
    m_mapHeapObjects.clear();
	m_classIdLookup.clear();
	m_objectIdLookup.clear();

    
    if (NULL != m_pStats) {
        delete m_pStats;
        m_pStats = NULL;
    }

    if (0 != m_dwOptions) {
        m_dwOptions = 0;
    }
    
    if (NULL != m_wszCustomSnapshotAction) {
        m_wszCustomSnapshotAction = NULL;
    }
    

    // then the profiler specific ones
    DeleteCriticalSection(& m_cs);    

    // then the runtime specific ones
    if (NULL != m_pInfo) {
        m_pInfo->Release();
        m_pInfo = NULL;
    }

    // clear out all the process specific ones
    ZeroMemory(m_wszFilePath, 2 * MAX_PATH * sizeof(WCHAR));
    ZeroMemory(m_wszFileName, 2 * MAX_PATH * sizeof(WCHAR));

    if (NULL != m_dwPid) {
        m_dwPid = NULL;
    }

    if (NULL != m_hProc) {
        CloseHandle(m_hProc);
        m_hProc = NULL;
    }
    
    // and finally the system ones
    ZeroMemory(& m_sysInfo, sizeof(m_sysInfo));
    
    //////////////////////////////////

	if (NULL != g_pLog) {
        fclose(g_pLog);
        g_pLog = NULL;
    }

}


// This is ultimately derived from IUnknown. So....

HRESULT __stdcall OrangeProfiler::QueryInterface(const IID & iid, void** ppv)
{
    if (iid == IID_IUnknown) {
        * ppv = static_cast<ICorProfilerCallback*>(this); // original implementation
    }
    else if (iid == IID_ICorProfilerCallback) {
        * ppv = static_cast<ICorProfilerCallback*>(this);
    }
    else if (iid == IID_ICorProfilerCallback2) {
        * ppv = static_cast<ICorProfilerCallback2*>(this);
    }
    else if (iid == IID_ICorProfilerCallback3) {
        * ppv = static_cast<ICorProfilerCallback3*>(this);
    }
    else {
        * ppv = NULL;
        return E_NOINTERFACE;
    }
    reinterpret_cast<IUnknown*>(*ppv)->AddRef();
    return S_OK;
}


ULONG __stdcall OrangeProfiler::AddRef()
{
    return InterlockedIncrement(& m_cRef);
}


ULONG __stdcall OrangeProfiler::Release()
{
    if (0 == InterlockedDecrement(& m_cRef)) {
        delete this;
        return 0;
    }
    return m_cRef;
}


//*********************************************************************
//  Descripton: Retrieves the process's handle, ID, name and full-path.
//              Also captures system specific information (in a 
//              SYSTEM_INFO structure).
//  
//  Params:     n/a.
//
//  Return:     S_OK if method successful, else appropriate error code.
//  
//  Notes:      This method uses the TRACE, TRACEERROR macros to log any 
//              errors. Please ensure that this method is called only
//              after the underlying log-stream has been initialized.
//*********************************************************************

HRESULT OrangeProfiler::RetrieveSystemAndProcessInfo()
{
    HRESULT hr = S_OK;
    
    if (NULL == (m_hProc = GetCurrentProcess())) {
        hr = HRESULT_FROM_WIN32(GetLastError());
        TRACEERROR(hr, L"Failed to get currrent process's handle.");
        goto ErrReturn;
    }

    if (0 == (m_dwPid = GetCurrentProcessId())) {
        hr = HRESULT_FROM_WIN32(GetLastError());
        TRACEERROR(HRESULT_FROM_WIN32(GetLastError()), L"Failed to get currrent process's ID.");
        goto ErrReturn;
    }

    if (0 == GetModuleFileName(NULL, m_wszFilePath, 2 * MAX_PATH)) {
        hr = HRESULT_FROM_WIN32(GetLastError());
        TRACEERROR(hr, L"Call to Kernel32!GetModuleFileName failed.");
        goto ErrReturn;
    }

    if (0 == GetModuleBaseName(m_hProc, NULL, m_wszFileName, 2 * MAX_PATH)) {
        hr = HRESULT_FROM_WIN32(GetLastError());
        TRACEERROR(hr, L"Call to Psapi!GetModuleBaseName failed.");
        goto ErrReturn;
    }

	if (NULL != m_hProc) 
        IsWow64Process(m_hProc, & m_bIsWOW64Process); 

    // The MSDN documentation says that if we are running in WOW64, then we must
    // call GetNativeSystemInfo() instead of GetSystemInfo() to retrieve the 
    // highest address accessible to the app. 
    // However I've observed this - 
    // If I call GetNativeSystemInfo() on WOW64, the m_sysInfo.lpMaximumApplicationAddress is 0xFFFEFFFF (which is bogus).
    // While if I call GetSystemInfo() on WOW64, the m_sysInfo.lpMaximumApplicationAddress is 0x7FFEFFFF (which looks correct).
    // Temporarily commenting out the code below until I can figure this one out - 
    /*  
    if (TRUE == bIsWOW64Process) 
        GetNativeSystemInfo(& m_sysInfo);
    else */ 
        GetSystemInfo(& m_sysInfo);

    if (NULL == m_sysInfo.lpMaximumApplicationAddress) {
        hr = E_FAIL;
        TRACEERROR(hr, L"m_sysInfo.lpMaximumApplicationAddress is NULL");
        goto ErrReturn;
    }

    /////////////////////////////////////////////////////
ErrReturn:

    return hr;
}


