    //*********************************************************************
    //  Descripton: 
    //  
    //  Params:     
    //
    //  Return:     S_OK if method successful, else appropriate error code.
    //  
    //  Notes:      n/a
    //*********************************************************************

    HRESULT __stdcall OrangeProfiler::GarbageCollectionStarted(int cGenerations, BOOL generationCollected[], COR_PRF_GC_REASON reason)
    {
        Synchronize guard(& m_cs);
        /////////////////////////////////////////////////////

        HRESULT hr = S_OK;    

		DIAGNOSTIC(L"Received profiler GarbageCollectionStarted() notification.");

        // pre-condition checks
        if (NULL == m_pInfo) {
            hr = E_FAIL;
            TRACEERROR(hr, L"Failed a precondition check -> m_pInfo is NULL");
            goto ErrReturn;
        }

        int i = COR_PRF_GC_GEN_0;
        for (; i < cGenerations /* <= COR_PRF_GC_LARGE_OBJECT_HEAP*/; i++)
        {
            if (FALSE == generationCollected[i])
                break;
        }
        
        DWORD m_condemnedGeneration = --i;

		if (0 == m_cGCRefCnt) {
            m_classIdLookup.clear();
        }


/*
        if (0 == m_cGCRefCnt) {
            m_mapHeapObjects.clear();
        }
*/
        TRACE(L"<gc tid=\"0x%X\" refcnt=\"0x%X\" reason=\"%s\" condemned=\"0x%X\">", 
              GetCurrentThreadId(), 
              ++m_cGCRefCnt, 
              m_helper.GetGarbageCollectionReasonString(reason),
              m_condemnedGeneration);


        /////////////////////////////////////////////////////
    ErrReturn:
      
        //TRACE(L"</gcs>");
        return hr;
    }


    //*********************************************************************
    //  Descripton: 
    //  
    //  Params:     
    //
    //  Return:     S_OK if method successful, else appropriate error code.
    //  
    //  Notes:      n/a
    //*********************************************************************

    HRESULT __stdcall OrangeProfiler::GarbageCollectionFinished() 
    {
        Synchronize guard(& m_cs);
        /*TRACE(L"<gcf tid=\"0x%X\" refcnt=\"0x%X\">", GetCurrentThreadId(), --m_cGCRefCnt);*/ --m_cGCRefCnt;
         /////////////////////////////////////////////////////

        HRESULT hr = S_OK;   

		DIAGNOSTIC(L"Received profiler GarbageCollectionFinished() notification.");
        

        
        // pre-condition checks
        if (NULL == m_pInfo) {
            hr = E_FAIL;
            TRACEERROR(hr, L"Failed a precondition check -> m_pInfo is NULL");
            goto ErrReturn;
        }

		if (0 == m_cGCRefCnt) { // i.e. no more pending GCs.........
			m_classIdLookup.clear();
        }

/*
        if (m_dwOptions & DUMP_HEAP && 0 == m_cGCRefCnt) // i.e. no more pending GCs.........
        {
            hr = DumpHeap();
            HR_CHECK(hr, S_OK, L"OrangeProfiler::DumpHeap");

            m_mapHeapObjects.clear();
        }
*/

        if (m_dwOptions & DUMP_VADUMP) {
            hr = DisplayVirtualAddressSpace();
            HR_CHECK(hr, S_OK, L"OrangeProfiler::DisplayVirtualAddressSpace");        
        }

        if (m_dwOptions & DUMP_GENRANGES) {
            hr = DisplayGCGenerationRanges();
            HR_CHECK(hr, S_OK, L"OrangeProfiler::DisplayGCGenerationRanges");        
        }


        if (m_dwOptions & DUMP_MODULES) {
            hr = DumpModules();
            HR_CHECK(hr, S_OK, L"OrangeProfiler::DumpModules");        
        }
        
        if (m_dwOptions & CUSTOM_SNAPSHOT_ACTION) {
            hr = CustomSnapshotAction();
            HR_CHECK(hr, S_OK, L"OrangeProfiler::CustomSnapshotAction");                    
        }
        


        /////////////////////////////////////////////////////
    ErrReturn:

        TRACE(L"</gc>");
        return hr;
    }


    //*********************************************************************
    //  Descripton: 
    //  
    //  Params:     
    //
    //  Return:     S_OK if method successful, else appropriate error code.
    //  
    //  Notes:      n/a
    //*********************************************************************

    HRESULT __stdcall OrangeProfiler::MovedReferences(
      ULONG cMovedObjectIDRanges,
      ObjectID oldObjectIDRangeStart[] ,
      ObjectID newObjectIDRangeStart[] ,
      ULONG cObjectIDRangeLength[]
      )
    {
        Synchronize guard(& m_cs);
        TRACE(L"<mr tid=\"0x%X\">", GetCurrentThreadId());
        /////////////////////////////////////////////////////

        HRESULT hr = S_OK;    
  
        for (int i = 0; i < cMovedObjectIDRanges; i++)
        {
            
            TRACE(L"<range os=\"0x%X\" oe=\"0x%X\" ns=\"0x%X\" ne=\"0x%X\"/>", 
                  oldObjectIDRangeStart[i], 
                  oldObjectIDRangeStart[i] + cObjectIDRangeLength[i],
                  newObjectIDRangeStart[i], 
                  newObjectIDRangeStart[i] + cObjectIDRangeLength[i]);
            
            //m_mapHeapObjects[newObjectIDRangeStart[i]] = cObjectIDRangeLength[i];
        }

        /////////////////////////////////////////////////////
    ErrReturn:

        TRACE(L"</mr>");
        return hr;
    }


    //*********************************************************************
    //  Descripton: 
    //  
    //  Params:     
    //
    //  Return:     S_OK if method successful, else appropriate error code.
    //  
    //  Notes:      - The SurvivingReferences callbacks is sent out only 
    //              for non-compacting collections.
    //
    //              - Multiple SurvivingReferences callbacks might be 
    //              received during a particular garbage collection, due to 
    //              limited internal buffering, multiple threads reporting in 
    //              the case of server garbage collection, and other reasons. 
    //              In the case of multiple callbacks during a garbage collection, 
    //              the information is cumulative — all references that are 
    //              reported in any SurvivingReferences callback survive the 
    //              garbage collection. 
    //*********************************************************************

    HRESULT __stdcall OrangeProfiler::SurvivingReferences(ULONG cSurvivingObjectIDRanges, ObjectID objectIDRangeStart[], ULONG cObjectIDRangeLength[])
    {
        Synchronize guard(& m_cs);
        TRACE(L"<sr tid=\"0x%X\">", GetCurrentThreadId());
        /////////////////////////////////////////////////////

        HRESULT hr = S_OK;    

        for (int i = 0; i < cSurvivingObjectIDRanges; i++)
        {
            
            TRACE(L"<range s=\"0x%X\" e=\"0x%X\"/>", objectIDRangeStart[i], objectIDRangeStart[i] + cObjectIDRangeLength[i]);
            
            //m_mapHeapObjects[objectIDRangeStart[i]] = cObjectIDRangeLength[i];
        }

        /////////////////////////////////////////////////////
    ErrReturn:

        TRACE(L"</sr>");
        return hr;
    }


    //*********************************************************************
    //  Descripton: 
    //  
    //  Params:     
    //
    //  Return:     S_OK if method successful, else appropriate error code.
    //  
    //  Notes:      n/a
    //*********************************************************************

    HRESULT __stdcall OrangeProfiler::ObjectReferences(
      ObjectID objectId,
      ClassID classId,
      ULONG cObjectRefs,
      ObjectID objectRefIds[]
      )
    {
        Synchronize guard(& m_cs);
        /////////////////////////////////////////////////////

        HRESULT hr = S_OK;    

		ObjectInfo oi(objectId, m_pInfo);
		hr = oi.Init();
        HR_CHECK(hr, S_OK, L"ObjectInfo::Init");

        TRACE(L"<or o=\"%x\" s=\"%x\" g=\"%x\" c=\"%x\">", 
            objectId,
            oi.m_cbObjAlignedSize,
            oi.m_genRange.generation,
            oi.m_ClassId /*classId*/);

        for (int i = 0; i < cObjectRefs; i++)
        {
            TRACE(L"<r>%x</r>", objectRefIds[i]);
        }

		TRACE(L"</or>");

		

		// If the classId has not been encountered before, we shall dump out
		// its information.
		if (m_classIdLookup.end() ==  m_classIdLookup.find(oi.m_ClassId))
		{
			m_classIdLookup.insert(oi.m_ClassId);

			ClassInfo ci(oi.m_ClassId, m_pInfo);
	        hr = ci.Init();
	        HR_CHECK(hr, S_OK, L"ClassInfo::Init");

			// Bug Fix: Often times the type names will contain characters like '<' and '>'. 
			// Since we are writing out the trace file in XML format, we have to replace
			// those character with "&lt;" and "&gt;" respectively.
			std::wstring typeName;
			if (NULL != ci.m_wszTypeDef)
			{
				typeName = ci.m_wszTypeDef;
				std::size_t index = wstring::npos;

				while ((index = typeName.find(L"<")) != wstring::npos)
					typeName.replace(index, 1, L"&lt;");
				while ((index = typeName.find(L">")) != wstring::npos)
					typeName.replace(index, 1, L"&gt;");
			}

			TRACE(L"<c i=\"%x\" n=\"%s\" m=\"%x\" />", oi.m_ClassId, (NULL == ci.m_wszTypeDef) ? L"[UNKNOWN]" : typeName.c_str(), ci.m_ModuleId);
		}
		
        /////////////////////////////////////////////////////
    ErrReturn:

        return hr;
    }




