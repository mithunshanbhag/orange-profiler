    HRESULT __stdcall OrangeProfiler::RootReferences2(
      ULONG cRootRefs,
      ObjectID rootRefIds[],
      COR_PRF_GC_ROOT_KIND rootKinds[],
      COR_PRF_GC_ROOT_FLAGS rootFlags[],
      UINT_PTR rootIds[]
      )
    {
        Synchronize guard(& m_cs);

		for (int i = 0; i < cRootRefs; i++)
        {
            TRACE(L"<rr re=\"%x\" ro=\"%x\" rk=\"%x\" rf=\"%x\"/>", rootRefIds[i], rootIds[i], rootKinds[i], rootFlags[i]);
        }

        return S_OK;
    }


