    //  Return:     S_OK if method successful, else appropriate error code.
    //  
    //  Notes:      n/a
    //*********************************************************************

    HRESULT __stdcall OrangeProfiler::Shutdown()
    {
		Synchronize guard(& m_cs);
        /////////////////////////////////////////////////////
        
		DIAGNOSTIC(L"Received profiler Shutdown() notification.");
    	TRACE(L"</trace>");
        return S_OK;
    }


    //*********************************************************************
