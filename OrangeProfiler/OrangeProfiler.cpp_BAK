HRESULT OrangeProfiler::DisplayGCGenerationRanges()
{
    HRESULT hr = S_OK;
    ULONG cObjectRanges = 0;
    COR_PRF_GC_GENERATION_RANGE * pGcGenRanges = NULL; 

    // let us get the required size of caller-allocated buffer by
    // passing in a zero-length buffer first.
    hr = m_pInfo->GetGenerationBounds(0, & cObjectRanges, NULL);
    HR_CHECK(hr, S_OK, L"ICorProfilerInfo2::GetGenerationBounds");

    if (0 == cObjectRanges) {
        hr = E_FAIL;
        TRACEERROR(hr, L"Unexpected error -> ICorProfilerInfo2::GetGenerationBounds returned zero object ranges");
        goto ErrReturn;
    }

    // allocate memory for the buffer
    pGcGenRanges = new COR_PRF_GC_GENERATION_RANGE[cObjectRanges];
    if (NULL == pGcGenRanges) {
        hr = E_FAIL;
        TRACEERROR(hr, L"Failed to allocate memory");
        goto ErrReturn;
    }

    // now let us get the GC generation bounds now
    hr = m_pInfo->GetGenerationBounds(cObjectRanges, & cObjectRanges, pGcGenRanges);
    HR_CHECK(hr, S_OK, L"ICorProfilerInfo2::GetGenerationBounds");

    for (int i = 0; i < cObjectRanges; i++)
    {
        TRACE(L"<gen g=\"0x%X\" rs=\"0x%X\" rl=\"0x%X\" rlr=\"0x%X\"/>", 
            pGcGenRanges[i].generation,
            pGcGenRanges[i].rangeStart,
            pGcGenRanges[i].rangeLength,
            pGcGenRanges[i].rangeLengthReserved);
    }

    /////////////////////////////////////////////////////

ErrReturn:
    return hr;
}


