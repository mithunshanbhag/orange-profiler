//*********************************************************************
//  Descripton: <@TODO>
//  
//  Params:     <@TODO>
//
//  Return:     n/a
//  
//  Notes:      @TODO - We are trying to dump our SOS!DumpHeap style
//              here. However what we should really be doing is to
//              simply dump the bare-minimum to XML and re-create the
//              SOS!DumpHeap style output in post-processing step (by
//              parsing the XML via LINQ).
//*********************************************************************

HRESULT OrangeProfiler::DumpHeap()
{
    TRACE(L"<DUMPHEAP>");
    /////////////////////////////////////////////////////

    HRESULT hr = S_OK;
    ObjectID objectid = NULL;
    ULONG rangelen = 0;

    // some pre-condition checks
    if (NULL == m_pInfo) {
        hr = E_INVALIDARG;
        TRACEERROR(hr, L"pre-condition check failed -> m_pInfo");
        goto ErrReturn;
    }


    TRACE(L"%8s %8s %8s", L"Address", L"MT", L"Size" ); 


    m_mapHeapObjectsItr = m_mapHeapObjects.begin();
    while(m_mapHeapObjectsItr != m_mapHeapObjects.end())
    {
        objectid = m_mapHeapObjectsItr->first;
        
        while (objectid < m_mapHeapObjectsItr->first /*range start*/ + m_mapHeapObjectsItr->second /*range length*/)
        {
            ObjectInfo oi(objectid, m_pInfo);
            hr = oi.Init();
            HR_CHECK(hr, S_OK, L"ObjectInfo::Init");
        
            TRACE(L"%08x %08x %8d", objectid, oi.m_ClassId, oi.m_cbObjAlignedSize); 

            ClassInfo ci(oi.m_ClassId, m_pInfo);
            hr = ci.Init();
            HR_CHECK(hr, S_OK, L"ClassInfo::Init");

            if (0 != ci.m_cFields) {
                TRACE(L"%8s %8s %8s %20s %2s %8s %8s %s", L"MT", L"Field", L"Offset", L"Type", L"VT", L"Attr", L"Value", L"Name");
            }

            for (int i = 0; i < ci.m_cFields; i++)
            {
                LPWSTR wszAttr = NULL;
                
                if (IsFdStatic(ci.m_pFields[i].m_dwFieldAttr))
                    wszAttr = L"shared";
                else if (IsFdLiteral(ci.m_pFields[i].m_dwFieldAttr)) 
                    wszAttr = L"literal";
                else
                    wszAttr = L"instance";  


                

                //ClassInfo ci2(ci.m_pFields[i].m_ClassId, m_pInfo);
                //hr = ci2.Init();
                //HR_CHECK(hr, S_OK, L"ClassInfo::Init");
                    

                TRACE(L"%08x %8x %8x %20s %2s %8s %8s %s", 
                      ci.m_pFields[i].m_ClassId,
                      ci.m_pFields[i].m_fieldDefTok,
                      ci.m_pFields[i].m_ulFieldOffset,
                      /*ci.m_pFields[i].m_wszTypeDefName*/ L"?",
                      (ELEMENT_TYPE_VALUETYPE == ci.m_pFields[i].m_dwCPlusTypeFlag) ? L"1" : L"0",
                      wszAttr,
                      L"?",
                      ci.m_pFields[i].m_pwszFieldName);
            }
                      
            // skip to next object
            objectid += oi.m_cbObjAlignedSize;
        }
        
        ++m_mapHeapObjectsItr;
        
        if (m_mapHeapObjectsItr != m_mapHeapObjects.end()) {

            // Are there any free objects around?
            if (objectid < m_mapHeapObjectsItr->first) {
            
                // HACK ALERT: [MithunS]: I initially considered wrapping the free object in a ObjectInfo instance.
                // However it turns out that when we call Init() on it, there is an AV. Turns out that we cannot
                // call ICorProfilerInfo::GetClassFromObject on a free object. I opened bug Dev10: 635574 
                // on this. However this is really a corner case and has been "won't fixed". Hence the only way
                // for me to get the free object's classId/MethodTable is to reverse engineer. Every objectID 
                // is a pointer to a object on the heap. The first four bytes of the heap object is the Methodtable. 
                ULONG ulAlignedSize = 0;
                hr = ObjectInfo::GetAlignedSize(m_pInfo, objectid, & ulAlignedSize); 
                HR_CHECK(hr, S_OK, L"ObjectInfo::GetAlignedSize");                                
                
                TRACE(L"%08x %08x %8d Free", objectid, (*(ULONG *) objectid), ulAlignedSize); 
            }
        }
    }

    /////////////////////////////////////////////////////
ErrReturn:

    TRACE(L"</DUMPHEAP>");
    return hr;
}


