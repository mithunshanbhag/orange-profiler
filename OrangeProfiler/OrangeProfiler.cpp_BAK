HRESULT OrangeProfiler::CustomSnapshotAction()
{
    TRACE(L"<customaction>");
   /////////////////////////////////////////////////////

    HRESULT hr = S_OK;
    DWORD dwRet = 0;
    DWORD dwExitCode = 0;
    STARTUPINFO si = {0};
    PROCESS_INFORMATION pi = {0};

    si.cb = sizeof(si);
    
    DIAGNOSTIC(L"Starting custom action: %s", m_wszCustomSnapshotAction);

    dwRet = CreateProcess(
                NULL,
                m_wszCustomSnapshotAction, // Command line. 
                NULL,				// Process handle not inheritable. 
                NULL,				// Thread handle not inheritable. 
                FALSE,			// Set handle inheritance to FALSE. 
                0,					// No creation flags. 
                NULL,				// Use parent's environment block. 
                NULL,				// Use parent's starting directory. 
                &si,				// Pointer to STARTUPINFO structure.
                &pi );			// Pointer to PROCESS_INFORMATION structure.
    
    if (0 == dwRet) 
    {
        hr = HRESULT_FROM_WIN32(GetLastError());
    }
    HR_CHECK(hr, S_OK, L"Kernel32::CreateProcess");

    // Wait till 30 secs for child process to exit    
    dwRet = WaitForSingleObject(pi.hProcess, 30000);

    if (WAIT_TIMEOUT == dwRet)  
    {
        DIAGNOSTIC(L"Custom action taking longer than 30 secs. Proceedig without waiting........");
    }
    
    else if (WAIT_OBJECT_0 == dwRet) 
    {
        dwRet = GetExitCodeProcess(pi.hProcess, & dwExitCode);
        if (0 == dwRet) 
        {
            hr = HRESULT_FROM_WIN32(GetLastError());
        }
        HR_CHECK(hr, S_OK, L"Kernel32::GetExitCodeProcess");    
        DIAGNOSTIC(L"Custom action finished with exit code: %d", dwExitCode);
        TRACE(L"</exitcode>0x%x</exitcode>", dwExitCode);
    }

    else 
    {
        hr = HRESULT_FROM_WIN32(GetLastError());
        TRACEERROR(hr, L"Kernel32!WaitForSingleObject");
        goto ErrReturn;
    }
 
    /////////////////////////////////////////////////////
ErrReturn:

    // Dispose process and thread handles
    CloseHandle(pi.hProcess);
    CloseHandle(pi.hThread);
    
    TRACE(L"</customaction>");
    return hr;
}


