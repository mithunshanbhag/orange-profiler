    HRESULT __stdcall OrangeProfiler::ProfilerAttachComplete()
    {
		Synchronize guard(& m_cs);
        TRACE(L"<pac tid=\"0x%X\">", GetCurrentThreadId());
        /////////////////////////////////////////////////////
        
        HRESULT hr = S_OK;

		DIAGNOSTIC(L"Received profiler ProfilerAttachComplete() notification.");

        /////////////////////////////////////////////////////
    ErrReturn:

        TRACE(L"</pac>");
        return S_OK;
    }

