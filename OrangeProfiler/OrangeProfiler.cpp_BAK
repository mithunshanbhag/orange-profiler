//  Notes:      n/a
//*********************************************************************

HRESULT OrangeProfiler::DumpModules()
{
    TRACE(L"<DUMPMODULES>");
    /////////////////////////////////////////////////////

    HRESULT hr = S_OK;
    ULONG cModules = 0;
    ULONG cModulesFetched = 0;
    WCHAR wszModuleName[MAX_PATH] = {0};
    ULONG cchModuleName = 0;



    ICorProfilerModuleEnum * pModuleEnum = NULL;
    ModuleID * pModuleIds = NULL;

    hr = m_pInfo->EnumModules(& pModuleEnum);
    HR_CHECK(hr, S_OK, L"ICorProfilerInfo3::EnumModules");

    hr = pModuleEnum->GetCount(& cModules);
    HR_CHECK(hr, S_OK, L"ICorProfilerModuleEnum::GetCount");

    pModuleIds = new ModuleID[cModules];
    if (NULL == pModuleIds) {
        hr = E_OUTOFMEMORY;
        TRACEERROR(hr, L"Failed to allocate memory");
        goto ErrReturn;
    }
    
    hr = pModuleEnum->Next(cModules, pModuleIds, & cModulesFetched);
    HR_CHECK(hr, S_OK, L"ICorProfilerModuleEnum::Next");

    if (cModulesFetched != cModules) {
        hr = E_FAIL;
        TRACEERROR(hr, L"cModulesFetched != cModules");
        goto ErrReturn;
    }
    
    // For each module in the enumeration .......
    for (int idx = 0; idx < cModulesFetched; idx++)
    {
        hr = m_pInfo->GetModuleInfo(pModuleIds[idx], NULL, MAX_PATH, & cchModuleName, wszModuleName, NULL);
        HR_CHECK(hr, S_OK, L"ICorProfilerInfo::GetModuleInfo");
        
        TRACE(L"<module id=\"0x%X\", name=\"%s\"/>", pModuleIds[idx], wszModuleName);
    }
    

    /////////////////////////////////////////////////////
ErrReturn:

    TRACE(L"</DUMPMODULES>");
    return hr;

}


