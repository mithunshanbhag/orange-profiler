HRESULT OrangeProfiler::DisplayVirtualAddressSpace()
{
    HRESULT hr = S_OK;
    LPCVOID lpAddress = (LPCVOID)0;
    MEMORY_BASIC_INFORMATION buffer = {0};

    // pre-condition checks
    if (NULL == m_hProc) {
        hr = E_FAIL;
        TRACEERROR(hr, L"Failed a precondition check -> m_hProc is NULL");
        goto ErrReturn;
    }
    if (NULL == m_sysInfo.lpMaximumApplicationAddress) {
        hr = E_FAIL;
        TRACEERROR(hr, L"Failed a precondition check -> m_sysInfo.lpMaximumApplicationAddress is NULL");
        goto ErrReturn;
    }

    DIAGNOSTIC(L"max addr=0x%X", m_sysInfo.lpMaximumApplicationAddress);

    while (lpAddress < m_sysInfo.lpMaximumApplicationAddress)
    {
        if (0 == VirtualQueryEx(GetCurrentProcess(), lpAddress, & buffer, sizeof(MEMORY_BASIC_INFORMATION)))   {
            hr = HRESULT_FROM_WIN32(GetLastError());
            TRACEERROR(hr, L"Kernel32!VirtualQuery() failed.");
            goto ErrReturn;
        }

        TRACE(L"<va b=\"%x\" r=\"%x\" s=\"%x\" p=\"%x\" t=\"%x\"/>",
              buffer.BaseAddress, 
              buffer.RegionSize, 
              buffer.State,
			  buffer.Protect,
			  buffer.Type);

        //  increment pointer by current region size 
        lpAddress = (LPCVOID) ((ULONG)lpAddress + (ULONG) buffer.RegionSize);
        
        ZeroMemory(& buffer, sizeof(MEMORY_BASIC_INFORMATION));

    }

    /////////////////////////////////////////////////////
ErrReturn:

    return hr;
}


//*********************************************************************
//  Descripton: <@TODO>
//  
//  Params:     <@TODO>
//
//  Return:     n/a
//  
//  Notes:      n/a
//*********************************************************************

void OrangeProfiler::ThreadStubWrapper()
{
    HRESULT hr = S_OK;
    DWORD dwRet = 0;

    // Looping and waiting for suspension event to be signalled
    while (S_OK == hr && FALSE == m_bWorkerThreadExit) {

        dwRet = WaitForMultipleObjects(SENTINEL_HANDLE, m_hndWaitEvents, FALSE, INFINITE);
    
        if (WAIT_FAILED == dwRet) {
            hr = HRESULT_FROM_WIN32(GetLastError());
            continue;
        }

        else if (WAIT_TIMEOUT == dwRet) {
            hr =  HRESULT_FROM_WIN32(WAIT_TIMEOUT);
            continue;
        }

        else if (WAIT_OBJECT_0 <= dwRet && WAIT_OBJECT_0 + SENTINEL_HANDLE > dwRet) { // we have been signaled

            WaitEventHandles type = (WaitEventHandles) (dwRet - WAIT_OBJECT_0);

            // is the thread supposed to exit now?
            if (TRUE == m_bWorkerThreadExit) {
                continue;
            }

            // some necessary pre-condition check
            if (NULL == m_pInfo) {
                hr = E_FAIL;
                continue;
            }
            
            if (type == FORCEGC_EVENT_HANDLE) {
                // Now that we have been signaled to force a GC event ....
                DIAGNOSTIC(L"Calling ICorProfilerInfo::ForceGC()....");
                hr = m_pInfo->ForceGC(); 
                if (S_OK != hr) {
                    TRACEERROR(hr, L"ICorProfilerInfo::ForceGC");
                    continue;
                }
            }

            if (type == DETACH_EVENT_HANDLE) {
                // Now that we have been signaled to detach the profiler ....
                DIAGNOSTIC(L"Calling ICorProfilerInfo::RequestProfilerDetach()....");
                hr = m_pInfo->RequestProfilerDetach(0); 
                if (S_OK != hr) {
                    TRACEERROR(hr, L"ICorProfilerInfo3::RequestProfilerDetach");
                    continue;
                }
            }


        }

        // dwRet cannot be WAIT_ABANDONED since we are not waiting
        // for a mutex handle. But still ...... 
        else {
            hr = E_FAIL;
            continue;
        }
    }
}


HRESULT OrangeProfiler::ForceGCAsync()
{
    HRESULT hr = S_OK;
    DWORD dwRet = 0;

    // pre-condition checks
    if (NULL == m_pInfo) {
        hr = E_FAIL;
        TRACEERROR(hr, L"Failed a precondition check -> m_pInfo is NULL");
        goto ErrReturn;
    }

    dwRet = SetEvent(m_hndWaitEvents[(DWORD) FORCEGC_EVENT_HANDLE]);
    if (0 == dwRet) {
        hr = HRESULT_FROM_WIN32(GetLastError());        
        TRACEERROR(hr, L"Call to Kernel32!SetEvent failed. Unable to wake worker thread.");
        goto ErrReturn;
    }    

    /////////////////////////////////////////////////////
ErrReturn:
      
    return hr;
}


HRESULT OrangeProfiler::RequestProfilerDetachAsync()
{
    HRESULT hr = S_OK;
    DWORD dwRet = 0;

    // pre-condition checks
    if (NULL == m_pInfo) {
        hr = E_FAIL;
        TRACEERROR(hr, L"Failed a precondition check -> m_pInfo is NULL");
        goto ErrReturn;
    }

    dwRet = SetEvent(m_hndWaitEvents[(DWORD) DETACH_EVENT_HANDLE]);
    if (0 == dwRet) {
        hr = HRESULT_FROM_WIN32(GetLastError());        
        TRACEERROR(hr, L"Call to Kernel32!SetEvent failed. Unable to wake worker thread.");
        goto ErrReturn;
    }    

    /////////////////////////////////////////////////////
ErrReturn:
      
    return hr;
}



//*********************************************************************
//  Descripton: Common routine for OrangeProfiler to initialize itself.
//
//  Params:     [IN] IUnknown * pICorProfilerInfoUnk
//                  An IUnknown interface pointer which can be QI'ed 
//                  for the ICorProfilerInfo3 interface.
//
//  Return:     S_OK if method successful, else appropriate error code.
//  
//  Notes:      This is not a profiler callback.
//*********************************************************************

HRESULT OrangeProfiler::CommonInit(IUnknown * pICorProfilerInfoUnk, void * pvClientData, UINT cbClientData)
{    
    HRESULT hr = S_OK;
    USHORT usClrInstanceId = 0;
    COR_PRF_RUNTIME_TYPE clrRuntimeType = COR_PRF_DESKTOP_CLR;
    USHORT usClrMajorVersion = 0;
    USHORT usClrMinorVersion = 0;
    USHORT usClrBuildNumber = 0;
    USHORT usClrQFEVersion = 0;
    DWORD cchVersionString = MAX_PATH;
    WCHAR wszClrVersionString[MAX_PATH] = {0};
	wchar_t * wszDiagnosticInfo = NULL;
	wchar_t * wszCaptureVirtualAddress = NULL;
	wchar_t * wszTraceFileName = NULL;

    // pre-condition check
    if (NULL == pICorProfilerInfoUnk) {
        hr = E_INVALIDARG;
        TRACEERROR(hr, L"Invalid arg passed into OrangeProfiler::CommonInit -> pICorProfilerInfoUnk");
        goto ErrReturn;
    }

    // First order of business is to determine what runtime are we dealing with here?
    // Let us QI it for IID_ICorProfilerInfo3
    //  - If QI passes, then it is definitely V4
    //  - else if QI fails with E_NOINTERFACE, then it is definitely V2. Since we are
    //    a pure V4 profiler we shall cancel activation at this point.
    hr = pICorProfilerInfoUnk->QueryInterface(IID_ICorProfilerInfo3, (void **) & m_pInfo);
    if (E_NOINTERFACE == hr) {
        hr = CORPROF_E_PROFILER_CANCEL_ACTIVATION;
        goto ErrReturn;
    }
    else {
        HR_CHECK(hr, S_OK, L"QI for ICorProfilerInfo3 failed");
        m_pInfo->AddRef();
    }


	// We shall now read in the following settings 
    // - Has the user requested diagnostic logging?
	// - Has the user specified any custom snapshot action?
	// - Does the user choose to capture the virtual address ranges?
	// - What is the name of the trace file to be generated?

	if (m_bAttachingProfiler)
	{
		// TEMP CODE. Delete later
		g_DiagnosticInfoLevel |= TRACELEVEL_DIAGNOSTIC; // temp

		//AttachingProfilerOptions * opts = (AttachingProfilerOptions*) pvClientData;
		//DIAGNOSTIC(L"%s", opts->wszDiagnosticInfo);
		//DIAGNOSTIC(L"%s", opts->wszCaptureVirtualAddress);
		//DIAGNOSTIC(L"%s", opts->wszTraceFileName);
		//DIAGNOSTIC(L"%s", opts->wszCustomSnapshotAction);

		// END OF TEMP CODE. Delete later
	}
	else
	{
	    wszDiagnosticInfo = _wgetenv(L"OP_ENABLE_DIAGNOSTIC_INFO");
	    m_wszCustomSnapshotAction = _wgetenv(L"OP_CUSTOM_SNAPSHOT_ACTION");
	    wszCaptureVirtualAddress = _wgetenv(L"OP_DUMP_VIRTUAL_ADDRESS");
	    wszTraceFileName = _wgetenv(L"OP_TRACE_FILE_NAME");
	}

	if (NULL != wszDiagnosticInfo)
    {
        if (0 == wcscmp(wszDiagnosticInfo, L"1"))
            g_DiagnosticInfoLevel |= TRACELEVEL_DIAGNOSTIC;
    }
    DIAGNOSTIC(L"g_DiagnosticInfoLevel = 0x%X", g_DiagnosticInfoLevel);

    if (NULL != m_wszCustomSnapshotAction)
        m_dwOptions |= CUSTOM_SNAPSHOT_ACTION;
    DIAGNOSTIC(L"Custom snapshot action: %s", m_wszCustomSnapshotAction);

    if (NULL != wszCaptureVirtualAddress) 
    {
        if (0 == wcscmp(wszCaptureVirtualAddress, L"1"))
            m_dwOptions |= DUMP_VADUMP;
    }
    DIAGNOSTIC(L"m_dwOptions = 0x%X", m_dwOptions);

	if (NULL == wszTraceFileName)
        wszTraceFileName = L"orangetracefile.xml";
	DIAGNOSTIC(L"Attempting to create trace file: %s", wszTraceFileName);
    errno_t err = _wfopen_s(& g_pLog, wszTraceFileName, L"w+");
	if (!err) {   
		DIAGNOSTIC(L"Successfully created trace file: %s", wszTraceFileName);
	}
	else {
		DIAGNOSTIC(L"Failed to create trace file. errno = %d", err);
	}


	TRACE(L"<trace type=\"\">");

    // let us now retrieve the detailed version info via the profiling API.
    hr = m_pInfo->GetRuntimeInformation(
            & usClrInstanceId, 
            & clrRuntimeType, 
            & usClrMajorVersion, 
            & usClrMinorVersion,
            & usClrBuildNumber, 
            & usClrQFEVersion, 
            cchVersionString, 
            & cchVersionString,
            wszClrVersionString);
    HR_CHECK(hr, S_OK, L"ICorProfilerInfo3::GetRuntimeInformation");

	TRACE(L"<header>");
	TRACE(L"<system is64bit=\"%d\"/>", (m_bIsWOW64Process || 0 == m_sysInfo.wProcessorArchitecture) ?0 :1);
	TRACE(L"<process pid=\"%d\" name=\"%s\" path=\"%s\"/>", m_dwPid, m_wszFileName, m_wszFilePath);
    TRACE(L"<runtime instanceid=\"%d\" type=\"%s\" versionstring=\"%s\" majorversion=\"%d\" minorversion=\"%d\" build=\"%d\" qfeversion=\"%d\"/>", 
              usClrInstanceId, 
              m_helper.GetRuntimeTypeString(clrRuntimeType),
              wszClrVersionString,
              usClrMajorVersion,
              usClrMinorVersion,
              usClrBuildNumber,
              usClrQFEVersion);
	TRACE(L"</header>");

    // Create auto-reset events that will notify the worker thread to 
    // - trigger GC or 
    // - detach the profiler
    for (int i = 0; i < SENTINEL_HANDLE; i++)
    {
        m_hndWaitEvents[i] = CreateEvent(NULL, FALSE, FALSE, NULL);
        if (NULL == m_hndWaitEvents[i]) {
            hr = HRESULT_FROM_WIN32(GetLastError());
            TRACEERROR(hr, L"Call to Kernel32!CreateEvent failed.");
            goto ErrReturn;
        }
    }

    // initialize the worker thread
    m_hndWorkerThread = (HANDLE) _beginthreadex(
                                        NULL,
                                        0,
                                        & ForceGCThreadStub,
                                        (void *) this,
                                        0,
                                        (unsigned int*) & m_dwWorkerThreadId);
                                        
    if (0 == m_hndWorkerThread) {
        hr = E_FAIL;
        TRACEERROR(hr, L"Call to _beginthreadex failed. Unable to spawn worker thread.");
        goto ErrReturn;
    }    

    /////////////////////////////////////////////////////
ErrReturn:

    return hr;  
} 



    //*********************************************************************
    //  Descripton: Profiler intialize callback. 
    //  
    //  Params:     [IN] IUnknown * pICorProfilerInfoUnk
    //                  An IUnknown interface pointer which can be QI'ed 
    //                  for the ICorProfilerInfo3 interface.
    //
    //  Return:     S_OK if method successful, else appropriate error code.
    //  
    //  Notes:      n/a
    //*********************************************************************

    HRESULT __stdcall OrangeProfiler::Initialize(IUnknown * pICorProfilerInfoUnk)
    {
		Synchronize guard(& m_cs);
        /////////////////////////////////////////////////////

        HRESULT hr = S_OK;
		DWORD dwEventMask = COR_PRF_USE_PROFILE_IMAGES;

		DIAGNOSTIC(L"Received profiler Initialize() notification.");

        // pre-condition checks
        if (NULL != m_pInfo) {
            hr = E_FAIL;
            TRACEERROR(hr, L"Failed a precondition check -> m_pInfo was expected to be NULL");
            goto ErrReturn;
        }

		m_bAttachingProfiler = false;

        hr = CommonInit(pICorProfilerInfoUnk, 0, 0);
        HR_CHECK(hr, S_OK, L"OrangeProfiler::CommonInit");

		if (m_dwOptions & DUMP_HEAP)
		{
        	dwEventMask |= COR_PRF_MONITOR_GC;
		}

        hr = m_pInfo->SetEventMask(dwEventMask);
        HR_CHECK(hr, S_OK, L"ICorProfilerInfo3::SetEventMask");

		DIAGNOSTIC(L"Profiler event mask set to 0x%X.", dwEventMask);

        /////////////////////////////////////////////////////
    ErrReturn:
        return hr;
    }


    //*********************************************************************
    //  Descripton: 
    //  
    //  Params:     
    //
    //  Return:     S_OK if method successful, else appropriate error code.
    //  
    //  Notes:      n/a
    //*********************************************************************
        
    HRESULT __stdcall OrangeProfiler::InitializeForAttach(IUnknown * pICorProfilerInfoUnk, void * pvClientData, UINT cbClientData)
    {
		Synchronize guard(& m_cs);
        /////////////////////////////////////////////////////

        HRESULT hr = S_OK;
		DWORD dwEventMask = 0;

		DIAGNOSTIC(L"Received profiler InitializeForAttach() notification.");

        // pre-condition checks
        if (NULL != m_pInfo) {
            hr = E_FAIL;
            TRACEERROR(hr, L"Failed a precondition check -> m_pInfo was expected to be NULL");
            goto ErrReturn;
        }

		m_bAttachingProfiler = true;

        hr = CommonInit(pICorProfilerInfoUnk, pvClientData, cbClientData);
        HR_CHECK(hr, S_OK, L"OrangeProfiler::CommonInit");

		if (m_dwOptions & DUMP_HEAP)
		{
        	dwEventMask |= COR_PRF_MONITOR_GC;
		}

        hr = m_pInfo->SetEventMask(dwEventMask);
        HR_CHECK(hr, S_OK, L"ICorProfilerInfo3::SetEventMask");

		DIAGNOSTIC(L"Profiler event mask set to 0x%X.", dwEventMask);


        /////////////////////////////////////////////////////
    ErrReturn:
        return hr;
    }


    //*********************************************************************
    //  Descripton: 
