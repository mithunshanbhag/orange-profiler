using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Xml;
using System.Xml.Linq;
using System.IO;

namespace OrangeClient
{
    /////////////////////////////////////
    // ----< class TraceNavigator >----//
    /////////////////////////////////////

    /// <summary>
    /// This class is responsible for implementing methods that can be used to navigate through a 
    /// trace file/report. 
    /// NOTE: The traceNavigator class does not conduct much validation on inputs or conduct many 
    /// pre-condition checks. It makes an assumption that valid inputs are being passed in by the caller.
    /// </summary>
    public sealed class TraceNavigator
    {

        ///////////////////////////////////
        // public methods and properties //
        ///////////////////////////////////

        /// <summary>
        /// This command loads the specified trace file for analysis. If a trace file is already loaded when
        /// this command is called, the old trace gets unloaded and the new one is loaded.
        /// Note: This method conducts two passes over the xml file. This is because we use an XmlReader (which is 
        /// a forward only iterator) we cannot deduce total number of "snapshot" nodes simply by loading the file.
        /// Assumption: All pre-condition checks have been done at this point. Trace file is assumed to be valid. 
        /// </summary>
        public void ResetAndLoadTrace(string file)
        {
            Reset(true);
            LoadTrace(file);

            while (null != NextSnapshot())
                ++m_cSnapshots;

            Reset(false);
            LoadTrace(file);
        }
        

        /// <summary>
        /// Unloads any loaded trace file.
        /// <summary>        
        public string UnloadTrace()
        { 
            return Reset(true);
        }


        /// <summary>
        ///
        /// <summary>        
        public string TraceFile
        {
            get 
            {
                if (null == m_strTraceFileName)
                    throw new NullReferenceException();

                return m_strTraceFileName;
            }
        }

        /// <summary>
        ///
        /// <summary>        
        public int TotalSnapshots
        {
            get 
            {
                return m_cSnapshots;
            }
        }


        /// <summary>
        ///
        /// <summary>                
        public int CurrentSnapshotIndex
        {
            get
            {
                return m_iCurrIndex;
            }
        }
        
       
        /// <summary>
        ///
        /// <summary>        
        public XElement NextSnapshot()
        {
            while (m_xmlTraceReader.Read())
            {
                if ((m_xmlTraceReader.NodeType == XmlNodeType.Element) && (m_xmlTraceReader.Name.Equals(m_strStopTag)))
                {
                    ++m_iCurrIndex;

                    return m_xmlCurrentSnapshot = (XElement)XElement.ReadFrom(m_xmlTraceReader);                    
                }
            }

            return null;                    
        }


        /// <summary>
        ///
        /// <summary>                
        public XElement CurrentSnapshot
        {
            get
            {   
                if (m_iCurrIndex < 0) 
                   return null;

                return m_xmlCurrentSnapshot;
            }
        }


        /// <summary>
        ///
        /// <summary>                
        public XElement GotoSnapshot(int index)        
        {
            if (index >= m_cSnapshots || index < 0)
                return null;
        
            m_strTraceFileName = Reset(false);
            LoadTrace(m_strTraceFileName);

            while (m_iCurrIndex < index - 1)
                NextSnapshot();
                
            return NextSnapshot();
        }


        ///////////////////////////////////////
        // private fields and helper methods //
        ///////////////////////////////////////

        private enum TraceType
        {
            MEMORY_TRACE,
            RESERVED
        }

        private string m_strTraceFileName;
        private XmlReader m_xmlTraceReader;        
        private XElement m_xmlCurrentSnapshot; 
        private int m_cSnapshots;
        private int m_iCurrIndex;
        private static readonly string m_strStopTag = "gc"; // @todo - change this later. 


        /// <summary>
        /// Reloads the trace file and resets the iterator. Returns the name of the trace file
        /// on which the xmlreader was just closed.
        /// </summary>
        private string Reset(bool bFullReset)
        {
            if (null != m_xmlTraceReader)
            {
                m_xmlTraceReader.Close();
                m_xmlTraceReader = null;
            }

            m_xmlCurrentSnapshot = null;
            m_iCurrIndex = -1;

            if (bFullReset)
                m_cSnapshots = 0;
            
            string tempholder = m_strTraceFileName; 
            m_strTraceFileName = string.Empty;

            return tempholder;
        }


        /// <summary>
        /// <summary>
        private void LoadTrace(string file)
        {
            m_xmlTraceReader = XmlReader.Create(file);
            m_xmlTraceReader.MoveToContent();
            m_strTraceFileName = file;
        }

    }

    ///////////////////////////////////////////////////////////////////////////


    //////////////////////////////////////////////////
    // ----< partial class OrangeCoreExtension >----//
    //////////////////////////////////////////////////

    public sealed partial class OrangeCoreExtension
    {
        private static TraceNavigator traceNavigator = new TraceNavigator();

        private static readonly string tagAnalyzeHelp = "\r\nType 'help analyze' to see usage options.";
        private static readonly string tagUnloadHelp = "\r\nType 'help unload' to see usage options.";
        private static readonly string tagNextHelp = "\r\nType 'help next' to see usage options.";
        private static readonly string tagPrevHelp = "\r\nType 'help prev' to see usage options.";
        private static readonly string tagGotoHelp = "\r\nType 'help goto' to see usage options.";
        private static readonly string tagOutHelp = "\r\nType 'help out' to see usage options.";
        private static readonly string tagWhereHelp = "\r\nType 'help where' to see usage options.";
        private static readonly string tagDumpHeapHelp = "\r\nType 'help dumpheap' to see usage options.";

        /// <summary>
        /// The "Analyze" command.
        /// </summary>
        /// <param name="arguments"></param>
        [CommandDescription(
            CommandName = "analyze",
            MinimumAbbrev = 3,
            ShortHelp = @"@todo",
            LongHelp = ""
            )
        ]
        public static void AnalyzeTraceCmd(string arguments)
        {
            // pre-condition checks
            if (null == arguments)
                throw new ArgumentNullException("arguments");
            if (0 == arguments.Length)
                throw new OrangeShellException("Did you pass in location of the trace-file?" + tagAnalyzeHelp);

            arguments = Environment.ExpandEnvironmentVariables(arguments).ToLower().Trim().StripLeadingLaggingQuotes();

            if (!File.Exists(arguments))
                throw new OrangeShellException("Could not locate the file: " + arguments + ".\r\n" +
                                               "Are you sure you have specified the correct path and filename?");

            traceNavigator.ResetAndLoadTrace(arguments);
            Orange.Shell.WriteLine(OutputType.LOG, "Trace file loaded: " + arguments + "\r\n");
            Orange.Shell.WriteLine(OutputType.LOG, traceNavigator.TotalSnapshots + " snapshots detected" + "\r\n");
        }
        

        /// <summary>
        /// The "Unload" command.
        /// </summary>
        /// <param name="arguments"></param>
        [CommandDescription(
            CommandName = "unload",
            MinimumAbbrev = 3,
            ShortHelp = @"@todo",
            LongHelp = ""
            )
        ]
        public static void UnloadTraceCmd(string arguments)
        {
            // pre-condition checks
            if (null != arguments && 0 != arguments.Length)
                throw new OrangeShellException("Currently the quit/exit command does not support arguments." + tagUnloadHelp);
            if (string.IsNullOrEmpty(traceNavigator.TraceFile))
                throw new OrangeShellException("To use this command, a trace file has to be loaded first." + tagUnloadHelp);

            Orange.Shell.WriteLine(OutputType.LOG, "Trace file unloaded: " + traceNavigator.UnloadTrace() + "\r\n");
        }
        

        /// <summary>
        /// The "next" command.
        /// </summary>
        /// <param name="arguments"></param>
        [CommandDescription(
            CommandName = "next",
            MinimumAbbrev = 3,
            ShortHelp = @"@todo",
            LongHelp = ""
            )
        ]
        public static void NextSnapshotCmd(string arguments)
        {
            // pre-condition checks
            if (null != arguments && 0 != arguments.Length)
                throw new OrangeShellException("Currently the next command does not support arguments." + tagNextHelp);
            if (string.IsNullOrEmpty(traceNavigator.TraceFile))
                throw new OrangeShellException("To use this command, a trace file has to be loaded first." + tagNextHelp);

            if (0 == traceNavigator.TotalSnapshots)
                throw new OrangeShellException("No snapshots were detected in this trace.");

            if (null == traceNavigator.NextSnapshot()) // we are past the last snapshot. Return to snapshot #0.
                traceNavigator.GotoSnapshot(0);
                
            Orange.Shell.WriteLine(OutputType.LOG, "Snapshot #" + traceNavigator.CurrentSnapshotIndex + "\r\n");
        }


        /// <summary>
        /// The "prev" command.
        /// </summary>
        /// <param name="arguments"></param>
        [CommandDescription(
            CommandName = "prev",
            MinimumAbbrev = 3,
            ShortHelp = @"@todo",
            LongHelp = ""
            )
        ]
        public static void PrevSnapshotCmd(string arguments)
        {
            // pre-condition checks
            if (null != arguments && 0 != arguments.Length)
                throw new OrangeShellException("Currently the prev command does not support arguments." + tagPrevHelp);
            if (string.IsNullOrEmpty(traceNavigator.TraceFile))
                throw new OrangeShellException("To use this command, a trace file has to be loaded first." + tagPrevHelp);

            if (0 == traceNavigator.TotalSnapshots)
                throw new OrangeShellException("No snapshots were detected in this trace.");

            if (traceNavigator.CurrentSnapshotIndex > 0)
                traceNavigator.GotoSnapshot(traceNavigator.CurrentSnapshotIndex - 1);
            else if (traceNavigator.CurrentSnapshotIndex == -1)
                traceNavigator.GotoSnapshot(0);

            Orange.Shell.WriteLine(OutputType.LOG, "Snapshot #" + traceNavigator.CurrentSnapshotIndex + "\r\n");                  
        }



        /// <summary>
        /// The "goto" command.
        /// </summary>
        /// <param name="arguments"></param>
        [CommandDescription(
            CommandName = "goto",
            MinimumAbbrev = 3,
            ShortHelp = @"@todo",
            LongHelp = ""
            )
        ]
        public static void GotoSnapshotCmd(string arguments)
        {
            // pre-condition checks
            if (null == arguments)
                throw new ArgumentNullException("arguments");
            if (0 == arguments.Length)
                throw new OrangeShellException("Did you pass in the index of the snapshot?" + tagGotoHelp);
            if (string.IsNullOrEmpty(traceNavigator.TraceFile))
                throw new OrangeShellException("To use this command, a trace file has to be loaded first." + tagGotoHelp);
             
            int index = -1;
            if (false == CheckIfInteger(arguments, out index))
              throw new OrangeShellException("Did you pass in the index of the snapshot?" + tagGotoHelp);
                      
            if (0 == traceNavigator.TotalSnapshots)
                throw new OrangeShellException("No snapshots were detected in this trace.");

            if (index < 0)
                throw new OrangeShellException("Please pass in a valid snapshot index.");
            
            traceNavigator.GotoSnapshot(index);
            
            Orange.Shell.WriteLine(OutputType.LOG, "Snapshot #" + traceNavigator.CurrentSnapshotIndex + "\r\n");                  
        }


        /// <summary>
        /// The "out" command.
        /// </summary>
        /// <param name="arguments"></param>
        [CommandDescription(
            CommandName = "out",
            MinimumAbbrev = 3,
            ShortHelp = @"@todo",
            LongHelp = ""
            )
        ]
        public static void OutOfSnapshotCmd(string arguments)
        {
            // pre-condition checks
            if (null != arguments && 0 != arguments.Length)
                throw new OrangeShellException("Currently the out command does not support arguments." + tagOutHelp);
            if (string.IsNullOrEmpty(traceNavigator.TraceFile))
                throw new OrangeShellException("To use this command, a trace file has to be loaded first." + tagOutHelp);

            if (string.IsNullOrEmpty(traceNavigator.TraceFile))
                traceNavigator.ResetAndLoadTrace(traceNavigator.TraceFile);
        }



        /// <summary>
        /// The "where" command.
        /// </summary>
        /// <param name="arguments"></param>
        [CommandDescription(
            CommandName = "where",
            MinimumAbbrev = 3,
            ShortHelp = @"@todo",
            LongHelp = ""
            )
        ]
        public static void WhichSnapshotCmd(string arguments)
        {
            // pre-condition checks
            if (null != arguments && 0 != arguments.Length)
                throw new OrangeShellException("Currently the where command does not support arguments." + tagWhereHelp);
            if (string.IsNullOrEmpty(traceNavigator.TraceFile))
                throw new OrangeShellException("To use this command, a trace file has to be loaded first." + tagWhereHelp);                

            Orange.Shell.WriteLine(OutputType.LOG, "Snapshot #" + traceNavigator.CurrentSnapshotIndex + "\r\n");                  
        }
        


        /// <summary>
        /// The "DumpHeap" command.
        /// </summary>
        /// <param name="arguments"></param>
        [
            CommandDescription(
                CommandName = "dumpheap",
                MinimumAbbrev = 1,
                ShortHelp = @"Parses the xml report generated by the 'mem' command and displays heap objects.",
                LongHelp = ""
            )
        ]
        public static void DumpHeapCmd(string arguments)
        {
            // pre-condition checks
            if (null == arguments)
                throw new ArgumentNullException("arguments");
            if (string.IsNullOrEmpty(traceNavigator.TraceFile))
                throw new OrangeShellException("To use this command, a trace file has to be loaded first." + tagDumpHeapHelp);
            if (traceNavigator.CurrentSnapshotIndex < 0)
                throw new OrangeShellException("This command can only by used on snapshots. Please use next, prev or goto commands." + tagDumpHeapHelp);
                                    


//            if (0 == arguments.Length)
//                throw new OrangeShellException("Did you pass in location of the xml report file?" + tagCallbackStatsHelp);


            var heapObjs = from item in traceNavigator.CurrentSnapshot.Elements("or")
                            where Convert.ToInt32(item.Attribute("g").Value) == 3
                           select item;

            
            StringBuilder sb = new StringBuilder();
            sb.AppendFormat("{0,-10} {1,-10} {2,8} {3}\r\n", "Address", "MT", "Size", "Gen");
            sb.AppendFormat("{0,-10} {1,-10} {2,8} {3}\r\n", "=======", "==", "====", "===");
            
            
            foreach (var heapObj in heapObjs)
            {
                int objectid, classid, size, generation;
            
                if (!CheckIfInteger(heapObj.Attribute("o").Value, out objectid) ||
                    !CheckIfInteger(heapObj.Attribute("c").Value, out classid)  ||
                    !CheckIfInteger(heapObj.Attribute("s").Value, out size)     || 
                    !CheckIfInteger(heapObj.Attribute("g").Value, out generation))
                {
                    throw new OrangeShellException("Unexpected error while parsing trace file.\r\n");
                }
              
                sb.AppendFormat("0x{0,8:x8} 0x{1,8:x8} {2,8} {3}\r\n", objectid, classid, size, generation);
            }

            Orange.Shell.WriteLine(OutputType.LOG, sb.ToString());


        }


        /// <summary>
        /// The "vadump" command.
        /// </summary>
        /// <param name="arguments"></param>
        [
            CommandDescription(
                CommandName = "vadump",
                MinimumAbbrev = 1,
                ShortHelp = @"Parses the xml report generated by the 'mem' command and displays heap objects.",
                LongHelp = ""
            )
        ]
        public static void VadumpCmd(string arguments)
        {
            // pre-condition checks
            if (null == arguments)
                throw new ArgumentNullException("arguments");
            if (string.IsNullOrEmpty(traceNavigator.TraceFile))
                throw new OrangeShellException("To use this command, a trace file has to be loaded first." + tagDumpHeapHelp);
            if (traceNavigator.CurrentSnapshotIndex < 0)
                throw new OrangeShellException("This command can only by used on snapshots. Please use next, prev or goto commands." + tagDumpHeapHelp);
                                    


//            if (0 == arguments.Length)
//                throw new OrangeShellException("Did you pass in location of the xml report file?" + tagCallbackStatsHelp);


            var ranges = from item in traceNavigator.CurrentSnapshot.Elements("va").Elements("r")
                        select item;

            
            StringBuilder sb = new StringBuilder();
            sb.AppendFormat("{0,8} {1,8} {2,10} {3}\r\n", "Base", "Size", "State", "Protection");
            
            
            foreach (var range in ranges)
            {
                int baseaddress, regionsize;
            
                if (!CheckIfInteger(range.Attribute("b").Value, out baseaddress) ||
                    !CheckIfInteger(range.Attribute("r").Value, out regionsize)) 
                {
                    throw new OrangeShellException("Unexpected error while parsing trace file.\r\n");
                }
              
                sb.AppendFormat("{0,8:x8} {1,8} {2,10} {3}\r\n", 
                    baseaddress, 
                    regionsize, 
                    range.Attribute("s").Value,
                    range.Attribute("t").Value);
            }

            Orange.Shell.WriteLine(OutputType.LOG, sb.ToString());


        }


        /// <summary>
        /// The "gen" command.
        /// </summary>
        /// <param name="arguments"></param>
        [
            CommandDescription(
                CommandName = "gen",
                MinimumAbbrev = 1,
                ShortHelp = @"Parses the xml report generated by the 'mem' command and displays heap objects.",
                LongHelp = ""
            )
        ]
        public static void GenerationCmd(string arguments)
        {
            // pre-condition checks
            if (null == arguments)
                throw new ArgumentNullException("arguments");
            if (string.IsNullOrEmpty(traceNavigator.TraceFile))
                throw new OrangeShellException("To use this command, a trace file has to be loaded first." + tagDumpHeapHelp);
            if (traceNavigator.CurrentSnapshotIndex < 0)
                throw new OrangeShellException("This command can only by used on snapshots. Please use next, prev or goto commands." + tagDumpHeapHelp);
                                    


//            if (0 == arguments.Length)
//                throw new OrangeShellException("Did you pass in location of the xml report file?" + tagCallbackStatsHelp);


            var generations = from item in traceNavigator.CurrentSnapshot.Elements("gen").Elements("generation")
                              select item;

            
            StringBuilder sb = new StringBuilder();
            sb.AppendFormat("{0} {1} {2} {3}\r\n", "gen", "Range-Start", "Range-Length", "Range-Length-Reserved");
            sb.AppendFormat("{0} {1} {2} {3}\r\n", "===", "===========", "============", "=====================");
            
            
            foreach (var generation in generations)
            {
                int gen, rangeStart, rangeLen, rangeLenReserved;
            
                if (!CheckIfInteger(generation.Attribute("g").Value, out gen)              ||
                    !CheckIfInteger(generation.Attribute("s").Value, out rangeStart)       ||
                    !CheckIfInteger(generation.Attribute("rl").Value, out rangeLen)        || 
                    !CheckIfInteger(generation.Attribute("rlr").Value, out rangeLenReserved))
                {
                    throw new OrangeShellException("Unexpected error while parsing trace file.\r\n");
                }
              
                sb.AppendFormat("{0} {1} {2} {3}\r\n", gen, rangeStart, rangeLen, rangeLenReserved);
            }

            Orange.Shell.WriteLine(OutputType.LOG, sb.ToString());




        }





    

    }

}


