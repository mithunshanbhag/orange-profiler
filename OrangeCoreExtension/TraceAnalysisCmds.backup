    ////////////////////////////////////////
    // ----< class ClassInfoComparer >----//
    ////////////////////////////////////////

    public class ClassInfoComparer : IEqualityComparer<XElement>
    {
        /// <summary>
        /// 
        /// </summary>
        /// <param name="x"></param>
        /// <param name="y"></param>
        /// <returns></returns>
        public bool Equals(XElement x, XElement y)
        {
            return (x.Attribute("i").Value.Equals(y.Attribute("i").Value) 
                    && x.Attribute("m").Value.Equals(y.Attribute("m").Value)
                    && x.Attribute("n").Value.Equals(y.Attribute("n").Value));
        }

        /// <summary>
        /// 
        /// </summary>
        /// <param name="c"></param>
        /// <returns></returns>
        public int GetHashCode(XElement c)
        {
            return c.Attribute("i").Value.GetHashCode();
        }
    }

    ////////////////////////////////
    // ----< class ClassInfo >----//
    ////////////////////////////////

    #region ClassInfo

    public class ClassInfo : IEquatable<ClassInfo>, IComparable<ClassInfo>
    {
        /// <summary>
        /// /
        /// </summary>
        /// <param name="classinfo"></param>
        public ClassInfo(XElement classinfo)
        {
            m_Id = Convert.ToUInt64((classinfo.Attribute("i").Value), 16);
            m_moduleId = Convert.ToUInt64((classinfo.Attribute("m").Value), 16);
            m_ClassName = classinfo.Attribute("n").Value;
        }

        /// <summary>
        /// 
        /// </summary>
        public UInt64 Id
        {
            get { return m_Id; }
        }
        
        /// <summary>
        /// 
        /// </summary>
        public UInt64 ModuleId
        {
            get { return m_moduleId; }
        }

        /// <summary>
        /// 
        /// </summary>
        public string ClassName
        {
            get { return m_ClassName; }
        }

        /// <summary>
        /// Implementing the IEquatable<T> interface
        /// </summary>
        /// <param name="ci"></param>
        /// <returns></returns>
        public bool Equals(ClassInfo ci)
        { 
            return (null == ci)
                ? false
                : (this.Id == ci.Id
                  && this.ModuleId == ci.ModuleId
                  && this.ClassName.Equals(ci.ClassName, StringComparison.InvariantCultureIgnoreCase));
        }

        /// <summary>
        /// Overriding the Object.Equals while implementing the IEquatable<T> interface
        /// </summary>
        /// <param name="obj"></param>
        /// <returns></returns>
        public override bool Equals(object obj)
        {
            if (null == obj)
                return false;

            return (obj is ClassInfo)
                ? this.Equals(obj)
                : false;
        }

        /// <summary>
        /// Overriding Object.GetHashCode() while implementing the IEquatable<T> interface
        /// </summary>
        /// <returns></returns>
        public override int GetHashCode()
        {
            return this.ClassName.GetHashCode();
        }

        /// <summary>
        /// Implementing the IComparable<T> interface
        /// </summary>
        /// <param name="ci"></param>
        /// <returns></returns>
        public int CompareTo(ClassInfo ci)
        {
            if (!(this.Id == ci.Id))
                return this.Id.CompareTo(ci.Id);

            if (!(this.ClassName.Equals(ci.ClassName)))
                return string.Compare(this.ClassName, ci.ClassName, StringComparison.InvariantCultureIgnoreCase);
 
            return this.ModuleId.CompareTo(ci.ModuleId);
        }


        private UInt64 m_Id;
        private UInt64 m_moduleId;
        private string m_ClassName;
    }

    #endregion // ClassInfo

    ///////////////////////////////////////////////////////////////////////////

