    /////////////////////////////////
    // ----< class Generation >----//
    /////////////////////////////////

    #region Generation

    public class Generation
    {
        /// <summary>
        /// 
        /// </summary>
        /// <param name="generation"></param>
        public Generation(XElement generation)
        {
            m_gen = Convert.ToUInt64(generation.Attribute("g").Value.Substring(2), 16);
            m_rangeStart = Convert.ToUInt64(generation.Attribute("rs").Value.Substring(2), 16);
            m_rangeLength = Convert.ToUInt64(generation.Attribute("rl").Value.Substring(2), 16);
            m_rangeLengthReserved = Convert.ToUInt64(generation.Attribute("rlr").Value.Substring(2), 16);
        }

        /// <summary>
        /// 
        /// </summary>
        public UInt64 Gen
        {
            get { return m_gen; }
        }

        /// <summary>
        /// 
        /// </summary>
        public UInt64 RangeStart
        {
            get { return m_rangeStart;  }
        }

        /// <summary>
        /// 
        /// </summary>
        public UInt64 RangeLength
        {
            get { return m_rangeLength;  } 
        }

        /// <summary>
        /// 
        /// </summary>
        public UInt64 RangeLengthReserved
        {
            get { return m_rangeLengthReserved; }
        }


        private UInt64 m_gen;
        private UInt64 m_rangeStart;
        private UInt64 m_rangeLength;
        private UInt64 m_rangeLengthReserved;
    }

    #endregion // Generation

    ///////////////////////////////////////////////////////////////////////////

    ///////////////////////////////
    // ----< class Snapshot >----//
    ///////////////////////////////

    #region Snapshot

    public sealed class Snapshot
    {
        /// <summary>
        /// 
        /// </summary>
        /// <param name="snapshot"></param>
        public Snapshot(XElement snapshot)
        {
            var gens = snapshot.Elements("gen");
            foreach (var gen in gens)
                m_generations.Add(new Generation(gen));

            var objInfos = snapshot.Elements("o");
            foreach (var objInfo in objInfos)
                m_objectInfos.Add(new ObjectInfo(objInfo));

            var va_ranges = snapshot.Elements("va");
            foreach (var va_range in va_ranges)
                m_va_ranges.Add(new VARange(va_range));

            var rootRefs = snapshot.Elements("rr");
            foreach (var rootRef in rootRefs)
                m_rootRefs.Add(new RootReference(rootRef));

            var classInfos = snapshot.Elements("c").Distinct(new ClassInfoComparer());
            foreach (var classInfo in classInfos)
                m_classInfos.Add(new ClassInfo(classInfo));

            var moduleInfos = snapshot.Elements("m");
            foreach (var moduleInfo in moduleInfos)
                m_moduleInfos.Add(new ModuleInfo(moduleInfo));
        }

        /// <summary>
        /// 
        /// </summary>
        public List<ObjectInfo> ObjectInfos
        {
            get { return m_objectInfos; }
        }

        /// <summary>
        /// 
        /// </summary>
        public List<Generation> Generations
        {
            get { return m_generations; }
        }

        /// <summary>
        /// 
        /// </summary>
        public List<VARange> VirtualAddressRanges
        {
            get { return m_va_ranges; }
        }

        /// <summary>
        /// 
        /// </summary>
        public List<RootReference> RootReferences
        {
            get { return m_rootRefs; }
        }

        /// <summary>
        /// 
        /// </summary>
        public List<ClassInfo> ClassInfos
        {
            get { return m_classInfos; }
        }

        /// <summary>
        /// 
        /// </summary>
        public List<ModuleInfo> ModuleInfos
        {
            get { return m_moduleInfos; }
        }


        private List<Generation> m_generations = new List<Generation>();
        private List<ObjectInfo> m_objectInfos = new List<ObjectInfo>();
        private List<VARange> m_va_ranges = new List<VARange>();
        private List<RootReference> m_rootRefs = new List<RootReference>();
        private List<ClassInfo> m_classInfos = new List<ClassInfo>();
        private List<ModuleInfo> m_moduleInfos = new List<ModuleInfo>();  
    }

    #endregion // Snapshot

