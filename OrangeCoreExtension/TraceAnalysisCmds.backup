    #region ModuleInfo

    public class ModuleInfo 
    {
        /// <summary>
        /// 
        /// </summary>
        /// <param name="moduleinfo"></param>
        public ModuleInfo(XElement moduleinfo)
        {
            m_moduleId = Convert.ToUInt64((moduleinfo.Attribute("i").Value), 16);
            m_moduleName = moduleinfo.Attribute("n").Value;
            m_assemblyId = Convert.ToUInt64((moduleinfo.Attribute("as").Value), 16);
        }

        /// <summary>
        /// 
        /// </summary>
        public UInt64 ModuleId
        {
            get { return m_moduleId;  }
        }

        /// <summary>
        /// 
        /// </summary>
        public String ModuleName
        {
            get { return m_moduleName;  }
        }

        /// <summary>
        /// 
        /// </summary>
        public UInt64 AssemblyId
        {
            get { return m_assemblyId; }
        }


        private UInt64 m_moduleId;
        private string m_moduleName;
        private UInt64 m_assemblyId;
    }

    #endregion // ModuleInfo

